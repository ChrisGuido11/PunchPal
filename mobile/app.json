{
  "expo": {
    "name": "PunchPal",
    "slug": "punchpal-ai-coach",
    "scheme": "punchpal",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.punchpal.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "PunchPal uses speech to call out combos during workouts",
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.punchpal.app"
    },
    "extra": {
      "eas": {
        "projectId": "61f19f38-1c99-48db-b8a7-d53d0238a8a5"
      },
      "grokApiKey": "$EXPO_PUBLIC_VIBECODE_GROK_API_KEY"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8632074296834726~6685988576",
          "iosAppId": "ca-app-pub-8632074296834726~5383909951"
        }
      ]
    ],
    "owner": "crisguido"
  }
}
