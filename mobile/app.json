{
  "expo": {
    "name": "PunchPal",
    "slug": "punchpal",
    "scheme": "punchpal",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./icon.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.punchpal.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "PunchPal uses speech to call out combos during workouts",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.punchpal.app"
    },
    "extra": {
      "eas": {
        "projectId": ""
      },
      "grokApiKey": "$EXPO_PUBLIC_VIBECODE_GROK_API_KEY"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      ["expo-asset", { "assets": ["./assets"] }],
      "expo-build-properties",
      "expo-font",
      "expo-image",
      "expo-mail-composer",
      "expo-secure-store",
      "expo-sharing",
      "expo-sqlite",
      "expo-video",
      "expo-web-browser"
    ]
  }
}
